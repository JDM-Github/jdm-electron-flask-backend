# .env — copy this to .env and fill in your values
# Never commit the real .env to version control.

FLASK_ENV=development
SECRET_KEY=change-me
API_ACCESS=your-secret-token-here

MAX_WORKERS=2
REQUEST_TIMEOUT=60

# Example: external service credentials
# EXTERNAL_API_URL=http://localhost:8000
# EXTERNAL_API_KEY=your-key-here
